# Copie este arquivo para .env (não commite o .env).
# Dados em: Firebase Console → Configurações do projeto → Seus apps → SDK (npm).

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Obrigatórios para o app iniciar: API_KEY, AUTH_DOMAIN, PROJECT_ID, APP_ID.
# STORAGE_BUCKET e MESSAGING_SENDER_ID vêm do mesmo bloco de config do Console.

# --- Site no ar (Vercel) ---
# No painel: Project → Settings → Environment Variables
# Cadastre as MESMAS chaves acima (VITE_FIREBASE_...) em Production (e Preview se quiser).
# Depois: Redeploy. O Vite só injeta variáveis que existem no momento do build.

# --- IA do admin (OpenAI) ---
# NÃO use prefixo VITE_ (a chave não pode ir para o JavaScript do navegador).
# Na Vercel: OPENAI_API_KEY = sk-...
# Local com `vercel dev`: pode usar OPENAI_API_KEY no .env na raiz do projeto.
