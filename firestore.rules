rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Lista de administradores: um documento por UID (mesmo ID do Authentication).
    // Crie o documento manualmente no Console após criar o usuário admin.
    match /admins/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }
  }
}
